generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum PostType {
  REQUEST
  OFFER
}

enum PostStatus {
  OPEN
  FULFILLED
  CLOSED
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  bio          String?
  location     String?
  latitude     Float?
  longitude    Float?
  skills       String[]
  avatarUrl    String?
  role         Role     @default(USER)
  isBanned     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  posts            Post[]
  sentMessages     Message[]      @relation("sender")
  receivedMessages Message[]      @relation("receiver")
  reportsFiled     Report[]       @relation("reporter")
  reportsAgainst   Report[]       @relation("reportedUser")
  conversationsAsA Conversation[] @relation("participantA")
  conversationsAsB Conversation[] @relation("participantB")
  orgMemberships        OrganizationMember[]
  invitesReceived       OrganizationInvite[]  @relation("inviteRecipient")
  invitesSent           OrganizationInvite[]  @relation("inviteSender")
  communityMemberships  CommunityMember[]
  communityInvitesRecv  CommunityInvite[]     @relation("communityInviteRecipient")
  communityInvitesSent  CommunityInvite[]     @relation("communityInviteSender")
  communityJoinRequests CommunityJoinRequest[]
  fulfillments          PostFulfillment[]
}

model Post {
  id             String       @id @default(uuid())
  type           PostType
  status         PostStatus   @default(OPEN)
  title          String
  description    String
  category       String
  location       String?
  latitude       Float?
  longitude      Float?
  urgency        UrgencyLevel @default(MEDIUM)
  authorId       String
  organizationId String?
  communityId    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  author       User          @relation(fields: [authorId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  community    Community?    @relation(fields: [communityId], references: [id])
  reports      Report[]
  images       PostImage[]
  fulfillments PostFulfillment[]

  @@index([category])
  @@index([type])
  @@index([status])
  @@index([authorId])
  @@index([organizationId])
  @@index([communityId])
  @@index([latitude, longitude])
}

model PostImage {
  id        String   @id @default(uuid())
  url       String
  order     Int      @default(0)
  postId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostFulfillment {
  id             String   @id @default(uuid())
  postId         String
  name           String
  userId         String?
  organizationId String?
  createdAt      DateTime @default(now())

  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([postId])
  @@index([userId])
  @@index([organizationId])
}

model Conversation {
  id             String   @id @default(uuid())
  participantAId String
  participantBId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participantA User      @relation("participantA", fields: [participantAId], references: [id])
  participantB User      @relation("participantB", fields: [participantBId], references: [id])
  messages     Message[]

  @@unique([participantAId, participantBId])
}

model Message {
  id             String    @id @default(uuid())
  content        String
  senderId       String
  receiverId     String
  conversationId String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  sender       User         @relation("sender", fields: [senderId], references: [id])
  receiver     User         @relation("receiver", fields: [receiverId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
}

model Report {
  id             String       @id @default(uuid())
  reason         String
  details        String?
  status         ReportStatus @default(PENDING)
  reporterId     String
  reportedUserId String?
  postId         String?
  resolvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  reporter     User  @relation("reporter", fields: [reporterId], references: [id])
  reportedUser User? @relation("reportedUser", fields: [reportedUserId], references: [id])
  post         Post? @relation(fields: [postId], references: [id])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  description String?
  location    String?
  latitude    Float?
  longitude   Float?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      OrganizationMember[]
  invites      OrganizationInvite[]
  posts        Post[]
  fulfillments PostFulfillment[]

  @@index([name])
  @@index([latitude, longitude])
}

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrganizationInvite {
  id              String       @id @default(uuid())
  organizationId  String
  invitedUserId   String
  invitedById     String
  status          InviteStatus @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedUser  User         @relation("inviteRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("inviteSender", fields: [invitedById], references: [id])

  @@unique([organizationId, invitedUserId])
  @@index([invitedUserId])
  @@index([status])
}

model Community {
  id          String   @id @default(uuid())
  name        String
  description String?
  location    String?
  latitude    Float?
  longitude   Float?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      CommunityMember[]
  invites      CommunityInvite[]
  joinRequests CommunityJoinRequest[]
  posts        Post[]

  @@index([name])
  @@index([latitude, longitude])
}

model CommunityMember {
  id          String   @id @default(uuid())
  communityId String
  userId      String
  role        OrgRole  @default(MEMBER)
  joinedAt    DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
}

model CommunityInvite {
  id            String       @id @default(uuid())
  communityId   String
  invitedUserId String
  invitedById   String
  status        InviteStatus @default(PENDING)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  invitedUser User      @relation("communityInviteRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User      @relation("communityInviteSender", fields: [invitedById], references: [id])

  @@unique([communityId, invitedUserId])
  @@index([invitedUserId])
  @@index([status])
}

model CommunityJoinRequest {
  id          String       @id @default(uuid())
  communityId String
  userId      String
  status      InviteStatus @default(PENDING)
  message     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
  @@index([status])
}
