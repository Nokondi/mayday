{
  "name": "@mayday/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n shared,server -c blue,green \"npm run dev -w @mayday/shared\" \"tsx watch src/index.ts\"",
    "build": "cross-env DATABASE_URL=\"postgresql://placeholder:placeholder@localhost:5432/placeholder\" prisma generate && tsc",
    "start": "prisma migrate deploy && node dist/index.js",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:seed": "dotenv -e ../.env -- tsx src/prisma/seed.ts",
    "db:clear": "dotenv -e ../.env -- tsx src/prisma/clear.ts",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "test": "vitest",
    "test:run": "vitest run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@mayday/shared": "*",
    "@prisma/client": "^6.2.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^8.0.5",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/multer-s3": "^3.0.3",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
