# Database
DATABASE_URL=postgresql://mayday:mayday_dev@localhost:5432/mayday

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Spaces API Keys (only needed if you want to use DigitalOcean Spaces for file uploads)
# SPACES_ENDPOINT=
# SPACES_REGION=
# SPACES_KEY=
# SPACES_BUCKET=

# SMTP (Gmail) — used to send account confirmation emails.
# Use a Gmail App Password (https://myaccount.google.com/apppasswords), NOT your account password.
# 2FA must be enabled on the Google account for App Passwords to be available.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM="Mayday <your-address@gmail.com>"
